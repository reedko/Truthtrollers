# Publisher enrichment credentials (leave empty in source control)
OPENALEX_API_KEY=
GOOGLE_FACT_CHECK_API_KEY=
OPENCORPORATES_API_KEY=

# Publisher enrichment provider gates
OPENALEX_ENABLED=true
GOOGLE_FACT_CHECK_ENABLED=true
OPENCORPORATES_ENABLED=false
ADFONTES_ENABLED=false
ALLSIDES_ENABLED=false

# Allows Tavily search results to be interpreted by an LLM for publisher
# ratings. Keep false unless this non-authoritative fallback is explicitly wanted.
PUBLISHER_ENRICHMENT_ALLOW_SEARCH_LLM_FALLBACK=false
ENABLE_BEARING_SHADOW=false
ENABLE_BEARING_GATING=true
ENABLE_SNIPPET_BEARING_LLM=true
ENABLE_BEARING_PACKET=true
ENABLE_BEARING_PACKET_LIVE=true
